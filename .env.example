# Copy to .env and fill in. .env is git-ignored and must never be committed.

# ---- Notion ----
NOTION_TOKEN=
NOTION_SUBSCRIBERS_DB_ID=
NOTION_SENT_LOG_DB_ID=

# ---- Email (SMTP, e.g. Gmail with an app password) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@example.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=Bargain Hunter <you@example.com>

# ---- Maintainer alerts (failure / heartbeat notifications) ----
MAINTAINER_EMAIL=

# ---- Telegram (later channel; not used in v1, see PRD §14 decision 4) ----
TELEGRAM_BOT_TOKEN=
