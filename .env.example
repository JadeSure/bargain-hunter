# Copy to .env and fill in. .env is git-ignored and must never be committed.

# ---- Notion ----
NOTION_TOKEN=ntn_xxxxx
NOTION_PARENT_PAGE_ID=        # Only needed when running scripts/setup_notion.py
NOTION_SUBSCRIBERS_DB_ID=
NOTION_SENT_LOG_DB_ID=

# ---- Email (SMTP, e.g. Gmail with an app password) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=                # Gmail app password (16 chars), not your login password
EMAIL_FROM=Bargain Hunter Bot <you@gmail.com>

# ---- Maintainer alerts (failure / anomaly notifications) ----
MAINTAINER_EMAIL=you@example.com

# ---- Feedback worker (Cloudflare) ----
# Public URL of the deployed feedback worker. When set, the digest email shows
# per-deal 👍/👎 links; when blank, they are simply omitted.
FEEDBACK_BASE_URL=

# ---- Heartbeat / dead-man's switch ----
# e.g. a healthchecks.io ping URL. Pinged on every clean run so an external
# monitor can alert you if the whole pipeline goes silent.
HEALTHCHECK_URL=
