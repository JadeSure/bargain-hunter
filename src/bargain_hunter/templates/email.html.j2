<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bargain Hunter Digest</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; margin: 0; padding: 0; background: #f5f5f5; color: #111; }
  .wrap { max-width: 600px; margin: 24px auto; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
  .header { background: #ff6600; padding: 20px 24px; }
  .header h1 { margin: 0; color: #fff; font-size: 20px; }
  .header small { color: rgba(255,255,255,.8); font-size: 13px; }
  .deal { padding: 20px 24px; border-bottom: 1px solid #eee; }
  .deal:last-child { border-bottom: none; }
  .deal h2 { margin: 0 0 6px; font-size: 16px; }
  .deal h2 a { color: #111; text-decoration: none; }
  .deal h2 a:hover { text-decoration: underline; }
  .meta { display: flex; flex-wrap: wrap; gap: 10px; margin: 8px 0; font-size: 13px; color: #555; }
  .badge { background: #f0f0f0; border-radius: 4px; padding: 2px 8px; }
  .badge.price { background: #e8f5e9; color: #2e7d32; font-weight: 600; }
  .badge.hot { background: #fff3e0; color: #e65100; }
  .badge.watch { background: #e3f2fd; color: #1565c0; }
  .badge.discount { background: #fce4ec; color: #c62828; font-weight: 600; }
  .badge.level { background: #ede7f6; color: #4527a0; font-weight: 600; text-transform: uppercase; }
  .badge.level-top { background: #4527a0; color: #fff; }
  .reason { font-size: 12px; color: #888; margin-top: 6px; }
  .links { margin-top: 10px; font-size: 13px; }
  .links a { color: #ff6600; text-decoration: none; margin-right: 12px; }
  .links a:hover { text-decoration: underline; }
  .footer { padding: 16px 24px; font-size: 12px; color: #aaa; background: #fafafa; }
  .expiry { font-size: 12px; color: #c62828; }
</style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <h1>Bargain Hunter</h1>
    <small>{{ deals|length }} deal{{ 's' if deals|length != 1 else '' }} for {{ subscriber.name }}</small>
  </div>

  {% for item in deals %}
  {% set deal = item.deal %}
  <div class="deal">
    <h2><a href="{{ deal.url }}">{{ deal.title }}</a></h2>
    <div class="meta">
      {% if deal.price is not none and deal.price_confidence == 'high' %}
      <span class="badge price">${{ "%.2f"|format(deal.price) }}</span>
      {% endif %}
      {% if deal.discount_percent is not none %}
      <span class="badge discount">{{ "%.0f"|format(deal.discount_percent) }}% off</span>
      {% endif %}
      <span class="badge {{ item.track }}">{{ item.track|upper }}</span>
      {% if item.level %}
      <span class="badge level{{ ' level-top' if item.level == 'top' else '' }}">{{ item.level }}</span>
      {% endif %}
      <span class="badge">▲ {{ deal.votes_pos }}</span>
      {% if deal.comment_count %}
      <span class="badge">💬 {{ deal.comment_count }}</span>
      {% endif %}
    </div>
    {% if item.reason %}
    <div class="reason">{{ item.reason }}</div>
    {% endif %}
    {% if deal.expiry %}
    <div class="expiry">Expires {{ deal.expiry.strftime('%d %b %Y %H:%M AEST') }}</div>
    {% endif %}
    <div class="links">
      <a href="{{ deal.url }}">{{ source_labels.get(deal.source, deal.source|title) }} ↗</a>
      {% if deal.merchant_url %}
      <a href="{{ deal.merchant_url }}">Go to deal ↗</a>
      {% endif %}
      {% if item.feedback_up_url %}
      <a href="{{ item.feedback_up_url }}">👍 Good</a>
      <a href="{{ item.feedback_down_url }}">👎 Meh</a>
      {% endif %}
    </div>
  </div>
  {% endfor %}

  <div class="footer">
    Sent {{ sent_at }}.
    {% if unsubscribe_url %}
    &nbsp;·&nbsp;<a href="{{ unsubscribe_url }}" style="color:#aaa;">Unsubscribe</a>
    {% endif %}
  </div>
</div>
</body>
</html>
